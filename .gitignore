# =======================================================
# 1. Build Artifacts - Must be ignored
# =======================================================
Debug/
Release/
build/
*.elf
*.bin
*.hex
*.map
*.o
*.d
*.su
*.list
*.cyclo
*.dep
makefile
objects.list
objects.mk
sources.mk
subdir.mk

# =======================================================
# 2. IDE Settings & System Temporary Files - Recommended to ignore
# =======================================================
.settings/
.mxproject
*.launch
.DS_Store
Thumbs.db
*.tmp
*.bak
*.swp
*~

# =======================================================
# 3. Security & Cryptographic Material - Core Focus
# =======================================================
# By default, ignore all contents in crypto_data folder
crypto_data/*
# [Exception Rule] Force track public test data for repository functionality
# Preserve these files for users to run after cloning:
!crypto_data/data.bin
!crypto_data/pub.der
!crypto_data/sig.bin
!crypto_data/firmware.bin
# Note: priv.pem (private key) is blocked by first rule and will never be uploaded.

# =======================================================
# 4. Backup Files
# =======================================================
*.ioc.bak